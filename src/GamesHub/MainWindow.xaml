<Window x:Class="GamesHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Коллекция игр - Games Hub" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="Коллекция игр"
                          FontSize="28"
                          FontWeight="Bold"
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Хаб для настольных и интеллектуальных игр"
                          FontSize="14"
                          Foreground="#BDC3C7"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Главная">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Добро пожаловать в коллекцию игр!"
                                  FontSize="20"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,15"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                            <Run Text="Это хаб для создания игровых комнат с мультиплеером. "/>
                            <Run Text="Здесь вы можете играть в пошаговые настольные игры и интеллектуальные игры на основе телевизионных передач."/>
                        </TextBlock>

                        <TextBlock Text="Возможности:"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Margin="0,15,0,10"/>

                        <StackPanel Margin="20,0,0,0">
                            <TextBlock Text="• Создание игровых комнат с выбором игры" Margin="0,5"/>
                            <TextBlock Text="• Мультиплеер для игры по сети" Margin="0,5"/>
                            <TextBlock Text="• Система ролей: игроки, модераторы, организаторы, ведущие" Margin="0,5"/>
                            <TextBlock Text="• Встроенный чат для общения" Margin="0,5"/>
                            <TextBlock Text="• Поддержка различных типов игр" Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Игры">
                <Grid Margin="20">
                    <StackPanel>
                        <TextBlock Text="Доступные игры"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,15"/>

                        <TextBlock Text="Игры будут добавлены в следующих версиях."
                                  Foreground="Gray"
                                  FontStyle="Italic"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Комнаты">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Создать комнату"
                               Padding="15,8"
                               Background="#3498DB"
                               Foreground="White"
                               BorderThickness="0"
                               Cursor="Hand"/>
                        <Button Content="Обновить список"
                               Padding="15,8"
                               Margin="10,0,0,0"
                               Background="#95A5A6"
                               Foreground="White"
                               BorderThickness="0"
                               Cursor="Hand"/>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                            Background="#ECF0F1"
                            BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                       Padding="10"
                                       Margin="5"
                                       CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RoomName}"
                                                  FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Game.Name}"
                                                  Foreground="Gray"
                                                  Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="Настройки">
                <Grid Margin="20">
                    <StackPanel>
                        <TextBlock Text="Настройки"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,15"/>

                        <TextBlock Text="Настройки будут добавлены в следующих версиях."
                                  Foreground="Gray"
                                  FontStyle="Italic"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#34495E" Padding="10">
            <TextBlock Text="Games Collection v0.1.0 - WPF Edition"
                      Foreground="White"
                      HorizontalAlignment="Center"
                      FontSize="12"/>
        </Border>
    </Grid>
</Window>
